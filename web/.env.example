# Local development — copy to .env.local (never commit)
# Leave API_PROXY_TARGET empty to proxy /api/* to http://localhost:4000 (see next.config.ts)
API_PROXY_TARGET=
NEXT_PUBLIC_API_URL=

# Optional: server-side fetch base URL (rare; browser uses same-origin /api via proxy)
API_URL=

# Production (Railway web service) — set before build & runtime (no trailing slash):
# API_PROXY_TARGET=https://your-server-service.up.railway.app
# NEXT_PUBLIC_API_URL=https://your-server-service.up.railway.app
