# Local development — copy to .env.local (never commit)
# Browser uses same-origin /api/* (proxied). Do not set NEXT_PUBLIC_API_URL unless forcing direct calls.
API_PROXY_TARGET=
API_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FORCE_DIRECT_API=false

# Production (Railway web service) — set before build & at runtime (no trailing slash):
# API_PROXY_TARGET=https://server-production-e915.up.railway.app
# API_URL=https://server-production-e915.up.railway.app
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_FORCE_DIRECT_API=false
