# Local development — copy to .env (never commit .env)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/buddy_daves?schema=public"
JWT_SECRET="change-me-to-a-long-random-string"
PORT=4000
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
NODE_ENV=development

# Production (Railway server service) — example:
# DATABASE_URL=<from Railway PostgreSQL plugin>
# JWT_SECRET=<generate a new long random secret>
# PORT=4000
# CORS_ORIGIN=https://your-web-service.up.railway.app
# NODE_ENV=production
